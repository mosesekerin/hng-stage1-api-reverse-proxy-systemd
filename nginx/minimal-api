# ── HTTP → HTTPS redirect ─────────────────────────────────────────────────────
server {
    if ($host = api.mosesekerin.name.ng) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    listen [::]:80;
    server_name api.mosesekerin.name.ng;

    # Permanent redirect — tells clients and crawlers to update their bookmarks
    return 301 https://$host$request_uri;


}

# ── HTTPS Server ──────────────────────────────────────────────────────────────
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name api.mosesekerin.name.ng;

    # --- TLS (managed by Let's Encrypt / Certbot) ---
    ssl_certificate /etc/letsencrypt/live/api.mosesekerin.name.ng/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/api.mosesekerin.name.ng/privkey.pem; # managed by Certbot
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # --- Security Headers ---
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;

    # --- Proxy to Node.js ---
    location / {
        proxy_pass         http://127.0.0.1:3000;

        # Pass the original request host to Node — important for apps that
        # generate self-referential URLs (redirects, links, etc.)
        proxy_set_header   Host              $host;

        # Pass the real client IP — without this, Node sees 127.0.0.1 for all requests
        proxy_set_header   X-Real-IP         $remote_addr;

        # Append to the forwarding chain — supports multi-proxy setups (CDN → Nginx → Node)
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;

        # Tell Node the original protocol — so it knows the client used HTTPS
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Timeouts — prevents Nginx from holding open connections to a slow/dead Node process
        proxy_connect_timeout 5s;
        proxy_read_timeout    10s;
        proxy_send_timeout    10s;
    }

}
